<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
     <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>


    <style>
        body { background:#f4f6f9; }

        .stat-card {
            border-radius:15px;
            padding:20px;
            color:white;
        }

        .product-card {
            border-radius:15px;
            transition:0.3s;
        }

        .product-card:hover {
            transform:translateY(-5px);
            box-shadow:0 10px 20px rgba(0,0,0,0.08);
        }
    </style>
</head>
<body>

<nav class="navbar navbar-dark bg-dark sticky-top">
    <div class="container-fluid px-4">
        <span class="navbar-brand fw-bold">Admin Panel</span>

        <div class="d-flex gap-2">
            <a href="/dashboard" class="btn btn-outline-light btn-sm">
                Back to Shop
            </a>
            <a href="/logout" class="btn btn-danger btn-sm">
               <i class="fa-solid fa-right-from-bracket"></i>  Logout
            </a>
        </div>
    </div>
</nav>

<div class="container mt-4">

    <!-- Stats Section -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card bg-primary shadow">
                <h6>Total Users</h6>
                <h4><%= totalUsers %></h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card bg-success shadow">
                <h6>Total Products</h6>
                <h4><%= totalProducts %></h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card bg-warning shadow">
                <h6>Total Orders</h6>
                <h4><%= totalOrders %></h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card bg-danger shadow">
                <h6>Total Revenue</h6>
                <h4>₹ <%= totalRevenue %></h4>
            </div>
        </div>
    </div>

    <!-- Top Buttons -->
    <div class="mb-4 d-flex gap-2">
        <button class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addProductModal">
            + Add Product
        </button>

        <a href="/admin/orders" class="btn btn-warning">
            View Orders
        </a>

        <a href="/admin/customers" class="btn btn-info">
            View Customers
        </a>
    </div>

    <!-- Products Grid -->
    <div class="row">

        <% products.forEach(product => { %>

            <div class="col-md-3 mb-4">
                <div class="card product-card shadow-sm">

                    <img src="<%= product.images[0] %>"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;">

                    <div class="card-body">

                        <h6><%= product.name %></h6>
                        <p class="text-success fw-bold">₹ <%= product.price %></p>

                        <p>
                            <% if (product.stock > 0) { %>
                                <span class="badge bg-success">
                                    Stock: <%= product.stock %>
                                </span>
                            <% } else { %>
                                <span class="badge bg-danger">
                                    Out of Stock
                                </span>
                            <% } %>
                        </p>

                        <div class="d-flex gap-2">

                            <!-- Edit Button -->
                            <button class="btn btn-sm btn-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editModal<%= product._id %>">
                                Edit
                            </button>

                            <!-- Delete -->
                            <form action="/admin/delete-product/<%= product._id %>"
                                  method="POST"
                                  style="display:inline;">
                                <button class="btn btn-sm btn-danger"
                                        onclick="return confirm('Delete this product?')">
                                    Delete
                                </button>
                            </form>

                        </div>

                    </div>
                </div>
            </div>

            <!-- EDIT MODAL (INSIDE LOOP) -->
            <div class="modal fade"
                 id="editModal<%= product._id %>">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content p-4">

                        <h5>Edit Product</h5>

                        <form action="/admin/edit-product/<%= product._id %>"
                              method="POST"
                              enctype="multipart/form-data">

                            <input type="text"
                                   name="name"
                                   value="<%= product.name %>"
                                   class="form-control mb-2"
                                   required>

                            <input type="number"
                                   name="price"
                                   value="<%= product.price %>"
                                   class="form-control mb-2"
                                   required>

                            <textarea name="description"
                                      class="form-control mb-2"
                                      required><%= product.description %></textarea>

                            <input type="number"
                                   name="stock"
                                   value="<%= product.stock %>"
                                   class="form-control mb-3"
                                   required>

                            <label class="fw-bold">Existing Images</label>

                            <div class="d-flex flex-wrap gap-3 mb-3">
                                <% product.images.forEach(img => { %>
                                    <div>
                                        <img src="<%= img %>"
                                             style="width:80px;height:80px;object-fit:cover"
                                             class="rounded border mb-1">

                                        <div class="form-check">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="removeImages"
                                                   value="<%= img %>">
                                            <label class="form-check-label">
                                                Remove
                                            </label>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>

                            <label class="fw-bold">
                                Add New Images
                            </label>

                            <input type="file"
                                   name="newImages"
                                   class="form-control mb-3"
                                   multiple>

                            <small class="text-muted">
                                Total images must be between 4 and 6.
                            </small>

                            <button class="btn btn-success w-100 mt-3">
                                Update Product
                            </button>

                        </form>

                    </div>
                </div>
            </div>

        <% }) %>

    </div>

</div>

<!-- ADD PRODUCT MODAL -->
<div class="modal fade" id="addProductModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content p-4">

            <h4>Add Product</h4>

            <form action="/admin/add-product"
                  method="POST"
                  enctype="multipart/form-data">

                <input type="text"
                       name="name"
                       class="form-control mb-3"
                       placeholder="Product Name"
                       required>

                <input type="number"
                       name="price"
                       class="form-control mb-3"
                       placeholder="Price"
                       required>

                <textarea name="description"
                          class="form-control mb-3"
                          placeholder="Description"
                          required></textarea>

                <input type="number"
                       name="stock"
                       class="form-control mb-3"
                       placeholder="Stock Quantity"
                       required>

                <label class="fw-bold mb-2">
                    Upload Minimum 4 Images
                </label>

                <input type="file"
                       name="images"
                       class="form-control mb-3"
                       multiple
                       required>

                <button class="btn btn-primary w-100">
                    Add Product
                </button>

            </form>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>